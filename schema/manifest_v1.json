{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://speciesid.dev/schema/manifest_v1.json",
  "title": "SpeciesID Analysis Manifest",
  "description": "Input contract for the SpeciesID C analysis engine. Describes a run with samples and controls.",
  "type": "object",
  "required": ["manifest_version", "run_id", "index_path", "samples", "marker_panel"],
  "properties": {
    "manifest_version": {
      "type": "string",
      "const": "1.0.0",
      "description": "Schema version for forward compatibility"
    },
    "run_id": {
      "type": "string",
      "description": "Unique run identifier (UUID v4)"
    },
    "index_path": {
      "type": "string",
      "description": "Absolute path to the pre-built speciesid index file (.idx)"
    },
    "database_hash": {
      "type": "string",
      "description": "SHA-256 hash of the reference database used to build the index"
    },
    "calibration_profile_path": {
      "type": ["string", "null"],
      "description": "Optional absolute path to calibration profile file (.cal)"
    },
    "marker_panel": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["COI", "cytb", "12S", "16S", "NADH2", "NADH4", "NADH5"] },
      "description": "Marker IDs used in this run"
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/sample" }
    },
    "analysis_params": { "$ref": "#/$defs/analysis_params" },
    "run_metadata": { "$ref": "#/$defs/run_metadata" }
  },
  "$defs": {
    "sample": {
      "type": "object",
      "required": ["sample_id", "role", "fastq_path"],
      "properties": {
        "sample_id": { "type": "string", "description": "Unique sample identifier within this run" },
        "role": {
          "type": "string",
          "enum": ["sample", "positive_control", "negative_control", "extraction_blank"],
          "description": "sample = unknown test sample; positive_control = known-species spike; negative_control = no-template PCR control; extraction_blank = extraction-only control"
        },
        "fastq_path": { "type": "string", "description": "Absolute path to FASTQ file (.fq, .fq.gz, .fastq, .fastq.gz)" },
        "label": { "type": "string", "description": "Human-readable sample label" },
        "metadata": {
          "type": "object",
          "properties": {
            "product_type": { "type": "string", "description": "e.g. sausage, patty, minced_meat" },
            "claimed_species": { "type": "array", "items": { "type": "string" } },
            "batch_id": { "type": "string" },
            "extraction_kit": { "type": "string" },
            "extraction_date": { "type": "string", "format": "date" },
            "sequencing_platform": { "type": "string", "enum": ["Illumina", "IonTorrent", "Nanopore", "PacBio"] },
            "sequencing_date": { "type": "string", "format": "date" },
            "notes": { "type": "string" }
          }
        }
      }
    },
    "analysis_params": {
      "type": "object",
      "properties": {
        "detection_threshold": {
          "type": "number",
          "default": 0.001,
          "description": "Species weight-fraction floor for reporting (0.001 = 0.1% w/w)"
        },
        "prune_threshold": {
          "type": "number",
          "default": 0.0,
          "description": "Post-EM pruning threshold (0 = disabled)"
        },
        "n_bootstrap": {
          "type": "integer",
          "default": 0,
          "description": "Number of bootstrap resamples for stability (0 = disabled)"
        },
        "read_mode": {
          "type": "string",
          "enum": ["auto", "short", "long"],
          "default": "auto"
        },
        "control_adjustment": {
          "type": "boolean",
          "default": true,
          "description": "Enable control-aware contamination correction"
        },
        "out_of_panel_check": {
          "type": "boolean",
          "default": true,
          "description": "Enable unknown/out-of-panel species detection"
        },
        "resolvability_check": {
          "type": "boolean",
          "default": true,
          "description": "Enable marker resolvability analysis for ambiguity groups"
        }
      }
    },
    "run_metadata": {
      "type": "object",
      "properties": {
        "operator": { "type": "string", "description": "Lab technician ID" },
        "laboratory": { "type": "string" },
        "instrument_id": { "type": "string" },
        "pcr_cycles": { "type": "integer" },
        "library_prep_kit": { "type": "string" },
        "sequencing_run_id": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
